APP_NAME=DocuMind AI
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0

# CORS - danh sách domain được phép truy cập, phân cách bằng dấu phẩy
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5500

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=documind_ai

# File storage
UPLOAD_DIR=./uploads
FAISS_INDEX_DIR=./faiss_index
MAX_UPLOAD_SIZE_MB=50

# Ollama / LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0.1
OLLAMA_NUM_CTX=1024

# Embedding model (Ollama)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
CHUNK_SIZE=750
CHUNK_OVERLAP=150
TOP_K=4

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
